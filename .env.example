# =============================================================================
# ENVIRONMENT VARIABLES — Copy this file to .env and fill in your own values
# =============================================================================
# Run:  cp .env.example .env
# Then edit .env with your credentials. NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Ollama Cloud (free-tier) for the Generative AI Safety Analyst
# -----------------------------------------------------------------------------
# Sign in at https://ollama.com, open Settings → API Keys, and create a key.
# The free tier covers all of the cloud models below at zero cost.
OLLAMA_API_KEY=your-ollama-cloud-api-key-here

# -----------------------------------------------------------------------------
# OPTIONAL — Ollama Cloud model selection
# -----------------------------------------------------------------------------
# The primary model used for safety analysis (free-tier benchmarks favour
# gpt-oss:20b-cloud for its 5s latency + clean 6-key JSON contract).
# Override only if you have a specific reason to.
# OLLAMA_MODEL=gpt-oss:20b-cloud

# Comma-separated fallback chain — tried in order if the primary model fails
# (timeout, rate limit, parse error, missing JSON sections).
# OLLAMA_FALLBACK_MODELS=gemini-3-flash-preview:cloud,gpt-oss:120b-cloud,qwen3-coder:480b-cloud

# Override the Ollama Cloud base URL (only needed for self-hosted proxies).
# OLLAMA_API_BASE=https://ollama.com

# Per-model timeout in seconds. Reasoning models (gpt-oss:120b-cloud) can take
# 90-150s on long prompts, so 180s is the safe default.
# ANALYST_LLM_TIMEOUT=180

# How many missing schema fields to tolerate before falling back fully to the
# deterministic corpus-only response (default 2; "missing" means an empty
# root_cause / suggested_actions / best_practices).
# ANALYST_MAX_MISSING=2

# Override the system instruction. By default we load the GEPA-tuned prompt
# from `dspy_gepa_best_config.json` at import time.
# ANALYST_INSTRUCTION="<your custom system prompt>"

# Set to any non-empty value to prefix the fallback root_cause with the last
# error string — useful while debugging Ollama connectivity.
# ANALYST_DEBUG=1

# -----------------------------------------------------------------------------
# OPTIONAL — DSPy / GEPA prompt-optimization run (`dspy_gepa_benchmark.py`)
# -----------------------------------------------------------------------------
# By default DSPy uses the same Ollama Cloud model. Override only for sweeps.
# DSPY_MODEL=ollama_chat/gpt-oss:20b-cloud
# DSPY_API_BASE=https://ollama.com
# DSPY_REFLECTION_MODEL=ollama_chat/gpt-oss:20b-cloud

# =============================================================================
# LEGACY (Vertex AI / Gemini RAG) — only needed if you re-enable the stack in
# `legacy_rag_engine/`. Leave commented for the default Ollama-based MVP.
# =============================================================================
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_LOCATION=us-west1
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json
# VERTEX_ENDPOINT_ID=your-endpoint-id-here
# VERTEX_DEPLOYED_INDEX_ID=your-deployed-index-id
# GCS_BUCKET_NAME=your-bucket-name-here
