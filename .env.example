# =============================================================================
# ENVIRONMENT VARIABLES — Copy this file to .env and fill in your own values
# =============================================================================
# Run:  cp .env.example .env
# Then edit .env with your credentials. NEVER commit .env to version control.
# =============================================================================

# --- Google Cloud Platform Configuration ---
# Your GCP project ID (found in the GCP Console dashboard)
GCP_PROJECT_ID=your-gcp-project-id

# GCP region for Vertex AI (e.g., us-west1, us-central1, us-east1)
GCP_LOCATION=us-west1

# Path to your GCP service account key file (relative or absolute)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json

# --- Vertex AI Vector Search Configuration ---
# These values are output after running setup_cloud.py (Step 3)
# The Matching Engine Index Endpoint ID (numeric string)
VERTEX_ENDPOINT_ID=your-endpoint-id-here

# The Deployed Index ID (string you chose during deployment)
VERTEX_DEPLOYED_INDEX_ID=your-deployed-index-id

# --- Cloud Storage ---
# GCS bucket name for storing embeddings (created by setup_cloud.py)
GCS_BUCKET_NAME=your-bucket-name-here
